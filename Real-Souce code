local function refreshPlayerList()
    for _, row in pairs(playerRows) do
        row.frame:Destroy()
    end
    playerRows = {}

    local index = 0
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player then
            index = index + 1
            local row, distLabel = createPlayerRow(plr)
            row.LayoutOrder = index
            table.insert(playerRows, {player = plr, frame = row, distLabel = distLabel})
        end
    end

    playerListScroll.CanvasSize = UDim2.new(0, 0, 0, index * 26)
end

