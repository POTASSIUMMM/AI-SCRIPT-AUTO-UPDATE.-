end)

local function createESP(targetPlayer)
    if targetPlayer == player then return end
    local character = targetPlayer.Character
    if not character then return end
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return end
    if character:FindFirstChild("ESPHighlight") then return end

    local highlight = Instance.new("Highlight")
    highlight.Name = "ESPHighlight"
    highlight.FillColor = espColor
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.6
    highlight.OutlineTransparency = 0
    highlight.Parent = character

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ESPName"
    billboard.Size = UDim2.new(0, 100, 0, 30)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = character:FindFirstChild("Head") or humanoidRootPart

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextStrokeTransparency = 0
    label.Font = Enum.Font.SourceSansBold
    label.TextSize = 14
    label.Text = targetPlayer.Name
    label.Parent = billboard
end

local function removeESP(targetPlayer)
    local character = targetPlayer.Character
    if not character then return end
    local highlight = character:FindFirstChild("ESPHighlight")
    if highlight then highlight:Destroy() end
    local head = character:FindFirstChild("Head")
    if head then
        local billboard = head:FindFirstChild("ESPName")
        if billboard then billboard:Destroy() end
    end
end

local function refreshESP()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player then
            if state.espEnabled then
                if plr.Character then createESP(plr) end
            else
                if plr.Character then removeESP(plr) end
            end
        end
    end
end

